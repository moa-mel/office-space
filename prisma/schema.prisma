// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OfficeMemberRole {
  CREATOR
  ADMIN
  MEMBER
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

model User {
  id               Int            @id @default(autoincrement())
  identifier       String         @unique
  firstName        String
  lastName         String
  email            String         @unique
  password         String
  isVerified       Boolean        @default(false)
  emailVerifiedAt  DateTime?
  googleId         String?        @unique
  picture          String?
  verificationCode String?
  codeTTL          DateTime?
  offices          Office[]
  messages         Message[]
  participants     Participant[]
  messageReads     MessageRead[]
  officeMembers    OfficeMember[]
  bookings         Booking[]      @relation("BookingsCreated")
  receivedBookings Booking[]      @relation("BookingsReceived")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([email])
}

model Office {
  id            Int            @id @default(autoincrement())
  identifier    String
  name          String
  description   String
  ImageUrl      String?
  userId        Int
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  members       OfficeMember[]
  conversations Conversation[]
  bookings      Booking[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model OfficeMember {
  id        Int              @id @default(autoincrement())
  officeId  Int
  userId    Int
  role      OfficeMemberRole @default(MEMBER)
  office    Office           @relation(fields: [officeId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([officeId, userId])
}

model Conversation {
  id           String            @id @default(uuid())
  type         ConversationType  @default(DIRECT)
  name         String?
  imageUrl     String?
  officeId     Int
  office       Office            @relation(fields: [officeId], references: [id], onDelete: Cascade)
  participants Participant[]
  messages     Message[]
  meta         ConversationMeta?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([officeId])
  @@index([updatedAt])
}

model ConversationMeta {
  id             Int          @id @default(autoincrement())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastMessage    String?      @db.VarChar(200)
  lastMessageAt  DateTime     @default(now())
  lastSenderId   Int?
}

model Message {
  id             Int           @id @default(autoincrement())
  senderId       Int
  sender         User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  type           MessageType   @default(TEXT)
  mediaId        String?
  mediaType      String?
  mediaUrl       String?
  isDeleted      Boolean       @default(false)
  deletedFor     Int[]
  messageReads   MessageRead[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([conversationId])
  @@index([senderId])
}

model Participant {
  id             Int          @id @default(autoincrement())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model MessageRead {
  id        Int       @id @default(autoincrement())
  messageId Int
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model Booking{
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation("BookingsCreated", fields: [userId], references: [id], onDelete: Cascade)
  hostId    Int
  host      User      @relation("BookingsReceived", fields: [hostId], references: [id], onDelete: Cascade)
  officeId  Int
  office    Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)
  title     String?
  notes     String?       @db.Text
  timezone  String?       // E.g. "America/New_York"
  meetingUrl String?      // E.g. Zoom or Google Meet link
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
